model Company {
id String @id @default(cuid())
name String
plan String @default("starter")
createdAt DateTime @default(now())

users User[]
projects Project[]
}

model User {
id String @id @default(cuid())
email String @unique
password String
role String @default("owner")

companyId String
company Company @relation(fields:[companyId], references:[id])
}

model Project {
id String @id @default(cuid())
name String

companyId String
company Company @relation(fields:[companyId], references:[id])
}