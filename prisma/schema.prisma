generator client {
provider = "prisma-client-js"
engineType = "binary"
}

datasource db {
provider = "sqlite"
}

model Task {
id String @id @default(cuid())
title String
createdAt DateTime @default(now())
}

model Project {
id String @id @default(cuid())
name String
createdAt DateTime @default(now())
}

model Memory {
id String @id @default(cuid())
content String
createdAt DateTime @default(now())
}
