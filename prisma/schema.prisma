generator client {
provider = "prisma-client-js"
}

datasource db {
provider = "sqlite"
url = "file:./dev.db"
}

model User {
id String @id @default(cuid())
email String @unique
password String
companyId String
company Company @relation(fields: [companyId], references: [id])
}

model Company {
id String @id @default(cuid())
name String
users User[]
projects Project[]
}

model Project {
id String @id @default(cuid())
name String
companyId String
company Company @relation(fields: [companyId], references: [id])
}